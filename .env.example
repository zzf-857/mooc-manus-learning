# Docker Compose project
COMPOSE_PROJECT_NAME=mooc-manus
NGINX_PORT=8088

# PostgreSQL (local-development defaults; change the password outside a dev machine)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=manus_local_dev
POSTGRES_DB=manus
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:manus_local_dev@manus-postgres:5432/manus

# Redis
REDIS_HOST=manus-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API runtime
ENV=development
LOG_LEVEL=INFO
APP_CONFIG_FILEPATH=/data/config.yaml
FILE_STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/files

# Optional Tencent COS backend (set FILE_STORAGE_BACKEND=cos to enable)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

# Static sandbox used by the default Compose stack
SANDBOX_ADDRESS=manus-sandbox
SANDBOX_IMAGE=mooc-manus-sandbox:local
SANDBOX_NAME_PREFIX=mooc-manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPUS=2
SANDBOX_PIDS_LIMIT=512
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=localhost,127.0.0.1,manus-sandbox,manus-api,manus-postgres,manus-redis
