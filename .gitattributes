* text=auto

# Cross-platform source and container files must stay LF in Git and worktrees.
*.sh text eol=lf
Dockerfile text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.lock text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Native Windows helpers remain CRLF-friendly.
*.ps1 text eol=crlf

# Binary assets must never be normalized.
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.webp binary
